# Copy this file to .env.local and fill in your Supabase project's values.
# Find them in the Supabase dashboard: Project Settings → API.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Optional (see ADR-0011). Frontend crashes, unhandled rejections, and external-API failures are
# always logged to the browser console; set this to also POST them as JSON to a real log vendor's
# HTTP ingest endpoint (e.g. Axiom, Logflare). Leave unset for local dev — nothing else changes.
# VITE_ERROR_LOG_ENDPOINT=https://your-log-vendor-ingest-url
